# Admin-Passwort für die ERSTEINRICHTUNG (optional).
# Wird nur verwendet, wenn noch keine Credentials in der Datenbank existieren.
# Danach kann das Passwort über die UI unter "Benutzereinstellungen" geändert werden.
# Wenn weder dieses noch EASM_ADMIN_PASSWORD_HASH gesetzt ist, wird ein
# Zufalls-Passwort generiert und einmalig ins Backend-Log geschrieben
# (docker compose logs backend).
EASM_ADMIN_PASSWORD=

# Alternativ: vorgehashter argon2-Hash für die ERSTEINRICHTUNG.
# Erzeugen mit:
#   docker compose exec backend python -c "from argon2 import PasswordHasher; print(PasswordHasher().hash('DEIN_PASSWORT'))"
EASM_ADMIN_PASSWORD_HASH=

# TLS für den nginx-Frontend-Container (RP → EASM via HTTPS).
# on = HTTPS auf Port 3443 mit Self-Signed-Cert (wird automatisch erzeugt, Volume easm-tls)
# off = nur HTTP auf Port 3000
EASM_TLS=on

# Subject Alternative Names fürs Self-Signed-Cert (kommagetrennt, ohne Leerzeichen).
# Leer = Default (DNS:localhost,DNS:easm.local,IP:127.0.0.1)
# Beispiel: DNS:easm.intern.mainzer.one,IP:192.168.1.10
EASM_TLS_SAN=

# HSTS-Header auf dem HTTPS-Listener (on/off). Achtung: Aktiviert HSTS für den
# gesamten Host — bei gemischtem HTTP/HTTPS-Betrieb auf demselben Hostnamen
# kann der HTTP-Zugriff danach blockiert werden. Empfohlen erst im reinen
# HTTPS-Betrieb hinter dem Reverse-Proxy.
EASM_HSTS=off

# Zeitzone für den Cron-Scheduler (schedule-Feld in der Config).
# Default UTC — für lokale Zeit z.B. Europe/Berlin setzen.
TZ=Europe/Berlin

# Passwort für die interne PostgreSQL-Datenbank.
# DB ist nicht von außen erreichbar (nur internes Docker-Netz), trotzdem
# für Produktion ein eigenes starkes Passwort setzen.
EASM_DB_PASSWORD=

