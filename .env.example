# Admin password for INITIAL SETUP (optional).
# Only used when no credentials exist in the database yet.
# Afterwards, the password can be changed via the UI under "User Settings".
# If neither this nor EASM_ADMIN_PASSWORD_HASH is set, a random password is
# generated and written once to the backend log (docker compose logs backend).
EASM_ADMIN_PASSWORD=

# Alternative: pre-hashed argon2 hash for INITIAL SETUP.
# Generate with:
#   docker compose exec backend python -c "from argon2 import PasswordHasher; print(PasswordHasher().hash('YOUR_PASSWORD'))"
EASM_ADMIN_PASSWORD_HASH=

# TLS for the nginx frontend container (RP → EASM via HTTPS).
# on  = HTTPS on port 443 with self-signed cert (auto-generated, volume easm-tls)
# off = HTTP only on port 80
EASM_TLS=on

# Subject Alternative Names for the self-signed cert (comma-separated, no spaces).
# Empty = default (DNS:localhost,DNS:easm.local,IP:127.0.0.1)
# Example: DNS:easm.intern.mainzer.one,IP:192.168.1.10
EASM_TLS_SAN=

# HSTS header on the HTTPS listener (on/off). Caution: Enables HSTS for the
# entire host — with mixed HTTP/HTTPS operation on the same hostname, HTTP
# access may be blocked afterwards. Recommended only in pure HTTPS operation
# behind a reverse proxy.
EASM_HSTS=off

# Timezone for the cron scheduler (schedule field in config).
# Default: UTC — for local time set e.g. Europe/Berlin.
TZ=Europe/Berlin

# Password for the internal PostgreSQL database.
# The DB is not reachable from outside (internal Docker network only), but in
# production you should still set a dedicated strong password.
EASM_DB_PASSWORD=
